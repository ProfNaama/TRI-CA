doctype html
html
  head
    title= title 
    link(rel="stylesheet", href="/static/stylesheets/style.css")
  body
    div(class="container")
      div(class="header")
        h2
      div(class="left" )
        h2
      div(class="content" )
        if header_message
          h2(class="controlled_header")!=header_message
        if body_message
          div(class="controlled_body")!=body_message

        block content
      div(class="footer" )
        h2

